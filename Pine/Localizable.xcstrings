    "conflict.externalModify.message %@" : {
      "comment" : "Informative text when a file with unsaved changes was modified externally.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ wurde außerhalb von Pine geändert. Sie haben nicht gespeicherte Änderungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has been modified outside Pine. You have unsaved changes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ fue modificado fuera de Pine. Tiene cambios sin guardar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ a été modifié en dehors de Pine. Vous avez des modifications non enregistrées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ が Pine の外部で変更されました。未保存の変更があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@이(가) Pine 외부에서 수정되었습니다. 저장되지 않은 변경 사항이 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ foi modificado fora do Pine. Você tem alterações não salvas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ был изменён за пределами Pine. У вас есть несохранённые изменения."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 已在 Pine 外部被修改。您有未保存的更改。"
          }
        }
      }
    },
