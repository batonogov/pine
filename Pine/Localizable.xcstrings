        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ が Pine の外部で変更されました。未保存の変更があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@이(가) Pine 외부에서 수정되었습니다. 저장되지 않은 변경 사항이 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ foi modificado fora do Pine. Você tem alterações não salvas."
