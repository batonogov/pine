    "branch.uncommittedChanges.message %@" : {
      "comment" : "Alert message: you have uncommitted changes, switching to branch may lose them.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben nicht commitete Änderungen. Das Wechseln zu \"%@\" kann diese überschreiben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have uncommitted changes. Switching to \"%@\" may overwrite them."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiene cambios sin confirmar. Cambiar a \"%@\" puede sobrescribirlos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez des modifications non committées. Basculer vers « %@ » peut les écraser."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コミットされていない変更があります。「%@」に切り替えると上書きされる可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "커밋되지 않은 변경 사항이 있습니다. \"%@\"(으)로 전환하면 덮어쓸 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você tem alterações não commitadas. Trocar para \"%@\" pode sobrescrevê-las."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "У вас есть незафиксированные изменения. Переключение на «%@» может их перезаписать."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您有未提交的更改。切换到「%@」可能会覆盖它们。"
          }
        }
      }
    },
