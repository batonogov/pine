    "context.delete.confirmMessage %@" : {
      "comment" : "Message in the delete confirmation alert. %@ is the file/folder name.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchten Sie „%@“ wirklich in den Papierkorb legen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to move \"%@\" to the Trash?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Seguro que quieres mover «%@» a la papelera?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir placer « %@ » dans la corbeille ?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」をゴミ箱に入れてもよろしいですか？"
