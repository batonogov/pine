        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\"을(를) 휴지통으로 이동하시겠습니까?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem certeza de que deseja mover \"%@\" para o Lixo?"
