{
    "name": "Markdown",
    "extensions": ["md", "markdown"],
    "blockComment": {"open": "<!--", "close": "-->"},
    "rules": [
        {
            "pattern": "```[\\s\\S]*?```",
            "scope": "markdown.code.fenced"
        },
        {
            "pattern": "`[^`\\n]+`",
            "scope": "markdown.code"
        },
        {
            "pattern": "^#\\s+.*$",
            "scope": "markdown.heading.1",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "^##\\s+.*$",
            "scope": "markdown.heading.2",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "^###\\s+.*$",
            "scope": "markdown.heading.3",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "^####\\s+.*$",
            "scope": "markdown.heading.4",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "^#####\\s+.*$",
            "scope": "markdown.heading.5",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "^######\\s+.*$",
            "scope": "markdown.heading.6",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\\*\\*[^*\\n]+\\*\\*",
            "scope": "markdown.bold"
        },
        {
            "pattern": "__[^_\\n]+__",
            "scope": "markdown.bold"
        },
        {
            "pattern": "(?<=\\s|^)\\*[^*\\n]+\\*(?=\\s|$|[.,;:!?])",
            "scope": "markdown.italic",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "(?<=\\s|^)_[^_\\n]+_(?=\\s|$|[.,;:!?])",
            "scope": "markdown.italic",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\\[[^\\]]+\\]\\([^)]+\\)",
            "scope": "markdown.link"
        },
        {
            "pattern": "^\\s*[-*+]\\s",
            "scope": "markdown.list",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "^\\s*\\d+\\.\\s",
            "scope": "markdown.list",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "^>\\s.*$",
            "scope": "markdown.quote",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "^---+$",
            "scope": "markdown.rule",
            "options": ["anchorsMatchLines"]
        }
    ]
}
