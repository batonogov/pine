{
    "name": "YAML",
    "extensions": ["yml", "yaml"],
    "filePatterns": [".gitlab-ci.yml", "*.yml.j2", "*.yaml.j2"],
    "lineComment": "#",
    "rules": [
        {
            "pattern": "#.*$",
            "scope": "comment",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
            "scope": "string"
        },
        {
            "pattern": "'[^']*'",
            "scope": "string"
        },
        {
            "pattern": "^\\s*[\\w.-]+(?=\\s*:)",
            "scope": "attribute",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\\b(true|false|yes|no|null|~)\\b",
            "scope": "keyword"
        },
        {
            "pattern": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b",
            "scope": "number"
        },
        {
            "pattern": "---|\\.\\.\\.",
            "scope": "keyword"
        },
        {
            "pattern": "[|>][-+]?(?=\\s*$)",
            "scope": "keyword",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "!!?\\w+",
            "scope": "attribute"
        },
        {
            "pattern": "&\\w+|\\*\\w+",
            "scope": "attribute"
        }
    ]
}
