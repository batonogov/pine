{
    "name": "Makefile",
    "extensions": ["mk", "mak"],
    "fileNames": ["Makefile", "GNUmakefile", "makefile"],
    "filePatterns": ["Makefile.*", "*.mk"],
    "lineComment": "#",
    "rules": [
        {
            "pattern": "#.*$",
            "scope": "comment",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
            "scope": "string"
        },
        {
            "pattern": "'(?:[^'\\\\]|\\\\.)*'",
            "scope": "string"
        },
        {
            "pattern": "\\b(ifeq|ifneq|ifdef|ifndef|else|endif|define|endef|include|sinclude|override|export|unexport|vpath)\\b",
            "scope": "keyword"
        },
        {
            "pattern": "\\.(PHONY|DEFAULT|PRECIOUS|INTERMEDIATE|SECONDARY|SUFFIXES|DELETE_ON_ERROR|IGNORE|LOW_RESOLUTION_TIME|SILENT|EXPORT_ALL_VARIABLES|NOTPARALLEL|ONESHELL|POSIX)\\b",
            "scope": "keyword"
        },
        {
            "pattern": "\\$\\([a-zA-Z_][a-zA-Z0-9_]*\\s+",
            "scope": "function"
        },
        {
            "pattern": "\\$\\{[^}]+\\}|\\$\\([^)]+\\)",
            "scope": "attribute"
        },
        {
            "pattern": "\\$[@<^*?|]",
            "scope": "attribute"
        },
        {
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_./-]*(?=\\s*:)",
            "scope": "function",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\\b\\d+(\\.\\d+)?\\b",
            "scope": "number"
        }
    ]
}
