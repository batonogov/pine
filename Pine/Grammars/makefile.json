{
    "name": "Makefile",
    "extensions": ["mk", "mak"],
    "fileNames": ["Makefile", "makefile", "GNUmakefile", "BSDmakefile"],
    "filePatterns": ["Makefile.*", "*.mk"],
    "lineComment": "#",
    "rules": [
        {
            "pattern": "#.*$",
            "scope": "comment",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
            "scope": "string"
        },
        {
            "pattern": "'(?:[^'\\\\]|\\\\.)*'",
            "scope": "string"
        },
        {
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_.-]*\\s*(?::?=|\\?=|\\+=)",
            "scope": "attribute",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_./-]*\\s*:",
            "scope": "function",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\\b(ifeq|ifneq|ifdef|ifndef|else|endif|define|endef|include|sinclude|-include|override|export|unexport|vpath|undefine)\\b",
            "scope": "keyword"
        },
        {
            "pattern": "\\$\\([^)]+\\)|\\$\\{[^}]+\\}|\\$[<@^?*%+]|\\$[@<]",
            "scope": "attribute"
        },
        {
            "pattern": "\\$\\((?:subst|patsubst|strip|findstring|filter|filter-out|sort|word|wordlist|words|firstword|lastword|dir|notdir|suffix|basename|addsuffix|addprefix|join|wildcard|realpath|abspath|foreach|if|or|and|call|value|eval|origin|flavor|error|warning|info|shell)\\b",
            "scope": "function"
        },
        {
            "pattern": "\\b\\d+\\b",
            "scope": "number"
        }
    ]
}
