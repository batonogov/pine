{
    "name": "Prisma",
    "extensions": ["prisma"],
    "lineComment": "//",
    "rules": [
        {
            "pattern": "//.*$",
            "scope": "comment",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
            "scope": "string"
        },
        {
            "pattern": "\\b(model|enum|type|datasource|generator|true|false|null)\\b",
            "scope": "keyword"
        },
        {
            "pattern": "@@[a-zA-Z_][a-zA-Z0-9_]*",
            "scope": "attribute"
        },
        {
            "pattern": "@[a-zA-Z_][a-zA-Z0-9_.]*",
            "scope": "attribute"
        },
        {
            "pattern": "\\b(String|Int|Float|Boolean|DateTime|Json|Bytes|BigInt|Decimal|Unsupported)\\b",
            "scope": "type"
        },
        {
            "pattern": "\\b(autoincrement|now|uuid|cuid|dbgenerated)(?=\\s*\\()",
            "scope": "function"
        },
        {
            "pattern": "\\b\\d+(\\.\\d+)?\\b",
            "scope": "number"
        },
        {
            "pattern": "\\?",
            "scope": "keyword"
        },
        {
            "pattern": "\\[\\]",
            "scope": "keyword"
        }
    ]
}
