{
    "name": "SQL",
    "extensions": ["sql"],
    "rules": [
        {
            "pattern": "--.*$",
            "scope": "comment",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "/\\*[\\s\\S]*?\\*/",
            "scope": "comment"
        },
        {
            "pattern": "'(?:[^']|'')*'",
            "scope": "string",
            "options": ["caseInsensitive"]
        },
        {
            "pattern": "\\b(SELECT|INSERT|UPDATE|DELETE|FROM|WHERE|JOIN|INNER|LEFT|RIGHT|FULL|OUTER|CROSS|ON|AS|INTO|VALUES|SET|AND|OR|NOT|IN|EXISTS|BETWEEN|LIKE|IS|NULL|TRUE|FALSE|CASE|WHEN|THEN|ELSE|END|DISTINCT|ALL|ANY|SOME|UNION|INTERSECT|EXCEPT|ORDER|BY|GROUP|HAVING|LIMIT|OFFSET|FETCH|NEXT|ROWS|ONLY|ASC|DESC|WITH|RECURSIVE|RETURNING|CONFLICT|DO|NOTHING|LATERAL|WINDOW|OVER|PARTITION|FILTER)\\b",
            "scope": "keyword",
            "options": ["caseInsensitive"]
        },
        {
            "pattern": "\\b(CREATE|ALTER|DROP|TRUNCATE|RENAME|ADD|COLUMN|TABLE|VIEW|INDEX|SCHEMA|DATABASE|SEQUENCE|TRIGGER|FUNCTION|PROCEDURE|IF|REPLACE|CASCADE|RESTRICT|CONSTRAINT|PRIMARY|KEY|FOREIGN|REFERENCES|UNIQUE|CHECK|DEFAULT|AUTO_INCREMENT|SERIAL|IDENTITY|GRANT|REVOKE|COMMIT|ROLLBACK|SAVEPOINT|BEGIN|TRANSACTION|TEMPORARY|TEMP|MATERIALIZED|EXPLAIN|ANALYZE|VACUUM|REINDEX)\\b",
            "scope": "keyword",
            "options": ["caseInsensitive"]
        },
        {
            "pattern": "\\b(INT|INTEGER|SMALLINT|BIGINT|TINYINT|NUMERIC|DECIMAL|FLOAT|REAL|DOUBLE|PRECISION|CHAR|VARCHAR|TEXT|NCHAR|NVARCHAR|NTEXT|CLOB|BLOB|BINARY|VARBINARY|BOOLEAN|BOOL|DATE|TIME|TIMESTAMP|TIMESTAMPTZ|INTERVAL|DATETIME|YEAR|MONEY|UUID|JSON|JSONB|XML|ARRAY|BYTEA|INET|CIDR|MACADDR|BIT|VARBIT|POINT|LINE|POLYGON|CIRCLE|BOX|PATH|ENUM|REGCLASS|OID|RECORD|VOID)\\b",
            "scope": "type",
            "options": ["caseInsensitive"]
        },
        {
            "pattern": "\\b(COUNT|SUM|AVG|MIN|MAX|COALESCE|NULLIF|CAST|CONVERT|CONCAT|LENGTH|CHAR_LENGTH|SUBSTRING|SUBSTR|TRIM|UPPER|LOWER|REPLACE|POSITION|EXTRACT|DATE_PART|DATE_TRUNC|NOW|CURRENT_TIMESTAMP|CURRENT_DATE|CURRENT_TIME|AGE|TO_CHAR|TO_DATE|TO_NUMBER|TO_TIMESTAMP|ROUND|CEIL|CEILING|FLOOR|ABS|MOD|POWER|SQRT|RANDOM|GREATEST|LEAST|STRING_AGG|ARRAY_AGG|ROW_NUMBER|RANK|DENSE_RANK|LAG|LEAD|FIRST_VALUE|LAST_VALUE|NTH_VALUE|NTILE|GENERATE_SERIES|UNNEST|ISNULL|IFNULL|IIF)\\b",
            "scope": "function",
            "options": ["caseInsensitive"]
        },
        {
            "pattern": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b",
            "scope": "number"
        },
        {
            "pattern": "0x[0-9a-fA-F]+",
            "scope": "number"
        }
    ]
}
