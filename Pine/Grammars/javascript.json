{
    "name": "JavaScript",
    "extensions": ["js", "jsx", "mjs", "cjs"],
    "rules": [
        {
            "pattern": "//.*$",
            "scope": "comment",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "/\\*[\\s\\S]*?\\*/",
            "scope": "comment"
        },
        {
            "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
            "scope": "string"
        },
        {
            "pattern": "'(?:[^'\\\\]|\\\\.)*'",
            "scope": "string"
        },
        {
            "pattern": "`(?:[^`\\\\]|\\\\.)*`",
            "scope": "string"
        },
        {
            "pattern": "\\b(const|let|var|function|return|if|else|for|while|do|switch|case|break|continue|class|extends|new|this|super|import|export|from|default|try|catch|finally|throw|async|await|of|in|typeof|instanceof|true|false|null|undefined|void|delete|yield)\\b",
            "scope": "keyword"
        },
        {
            "pattern": "\\b(console|window|document|Math|JSON|Promise|Array|Object|String|Number|Boolean|Map|Set|RegExp|Error|Date)\\b",
            "scope": "type"
        },
        {
            "pattern": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b",
            "scope": "number"
        },
        {
            "pattern": "=>",
            "scope": "keyword"
        },
        {
            "pattern": "\\bfunction\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
            "scope": "function"
        }
    ]
}
