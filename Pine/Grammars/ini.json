{
    "name": "INI",
    "extensions": ["ini", "cfg", "conf", "properties"],
    "fileNames": [".editorconfig"],
    "lineComment": "#",
    "rules": [
        {
            "pattern": "[#;].*$",
            "scope": "comment",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
            "scope": "string"
        },
        {
            "pattern": "^\\s*\\[[^\\]]+\\]",
            "scope": "keyword",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "^\\s*[a-zA-Z_][a-zA-Z0-9_.:-]*\\s*(?==)",
            "scope": "attribute",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\\b(true|false|yes|no|on|off)\\b",
            "scope": "keyword",
            "options": ["caseInsensitive"]
        },
        {
            "pattern": "\\b\\d+(\\.\\d+)?\\b",
            "scope": "number"
        }
    ]
}
