{
    "name": "INI",
    "extensions": ["ini", "conf", "cfg", "properties", "env"],
    "fileNames": [".editorconfig", ".gitconfig", ".npmrc", ".pylintrc"],
    "filePatterns": [".env.*"],
    "lineComment": "#",
    "rules": [
        {
            "pattern": "#.*$",
            "scope": "comment",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": ";.*$",
            "scope": "comment",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
            "scope": "string"
        },
        {
            "pattern": "'(?:[^'\\\\]|\\\\.)*'",
            "scope": "string"
        },
        {
            "pattern": "^\\s*\\[[^\\]]+\\]",
            "scope": "keyword",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "^\\s*[a-zA-Z_][a-zA-Z0-9_.-]*(?=\\s*[=:])",
            "scope": "attribute",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "\\b(true|false|yes|no)\\b",
            "scope": "keyword"
        },
        {
            "pattern": "\\$\\{[^}]+\\}|\\$[a-zA-Z_][a-zA-Z0-9_]*",
            "scope": "attribute"
        },
        {
            "pattern": "\\b\\d+(\\.\\d+)?\\b",
            "scope": "number"
        }
    ]
}
