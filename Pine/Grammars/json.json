{
    "name": "JSON",
    "extensions": ["json"],
    "filePatterns": ["*.json.j2"],
    "rules": [
        {
            "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"\\s*(?=:)",
            "scope": "attribute"
        },
        {
            "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
            "scope": "string"
        },
        {
            "pattern": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b",
            "scope": "number"
        },
        {
            "pattern": "\\b(true|false|null)\\b",
            "scope": "keyword"
        }
    ]
}
