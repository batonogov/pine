{
    "name": "Kotlin",
    "extensions": ["kt", "kts"],
    "lineComment": "//",
    "rules": [
        {
            "pattern": "//.*$",
            "scope": "comment",
            "options": ["anchorsMatchLines"]
        },
        {
            "pattern": "/\\*[\\s\\S]*?\\*/",
            "scope": "comment"
        },
        {
            "pattern": "\"\"\"[\\s\\S]*?\"\"\"",
            "scope": "string"
        },
        {
            "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
            "scope": "string"
        },
        {
            "pattern": "'(?:[^'\\\\]|\\\\.)'",
            "scope": "string"
        },
        {
            "pattern": "\\$\\{[^}]+\\}",
            "scope": "attribute"
        },
        {
            "pattern": "\\$[a-zA-Z_][a-zA-Z0-9_]*",
            "scope": "attribute"
        },
        {
            "pattern": "@[a-zA-Z_][a-zA-Z0-9_.]*",
            "scope": "attribute"
        },
        {
            "pattern": "\\b(abstract|actual|annotation|as|break|by|catch|class|companion|const|constructor|continue|crossinline|data|do|else|enum|expect|external|final|finally|for|fun|get|if|import|in|infix|init|inline|inner|interface|internal|is|it|lateinit|noinline|null|object|open|operator|out|override|package|private|protected|public|reified|return|sealed|set|super|suspend|tailrec|this|throw|try|typealias|val|var|vararg|when|where|while|true|false)\\b",
            "scope": "keyword"
        },
        {
            "pattern": "\\b(Any|Boolean|Byte|Char|Double|Float|Int|Long|Nothing|Short|String|Unit|Array|List|Map|Set|MutableList|MutableMap|MutableSet|Pair|Triple|Sequence|Comparable|Iterable|Collection)\\b",
            "scope": "type"
        },
        {
            "pattern": "\\b\\d+[lL]?\\b",
            "scope": "number"
        },
        {
            "pattern": "\\b\\d+\\.\\d+[fF]?\\b",
            "scope": "number"
        },
        {
            "pattern": "\\b\\d[\\d_]*\\.?\\d*[eE][+-]?\\d+[fF]?\\b",
            "scope": "number"
        },
        {
            "pattern": "0[xX][0-9a-fA-F_]+[lL]?",
            "scope": "number"
        },
        {
            "pattern": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()",
            "scope": "function"
        }
    ]
}
